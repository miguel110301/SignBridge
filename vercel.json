{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "functions": {
    "apps/api/index.js": {
      "runtime": "@vercel/node",
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/:path*",  "destination": "/apps/api/index.js" },
    { "source": "/health",      "destination": "/apps/api/index.js" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
